<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#f2f5f4" android:animateLayoutChanges="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#074838" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/app_name" android:textColor="#ffffff" android:textSize="22sp" android:textStyle="bold" />
        <Button android:id="@+id/btnLangToggle" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/lang_toggle" android:textColor="#c4933a" android:background="?android:attr/selectableItemBackground" />
        <LinearLayout android:id="@+id/tabsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/roleTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="20sp" android:textStyle="bold" />
            <LinearLayout android:id="@+id/nfcZone" android:layout_width="match_parent" android:layout_height="180dp" android:gravity="center" android:orientation="vertical" android:background="#FAFCFB">
                <TextView android:id="@+id/nfcText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nfc_scan_hint" />
                <TextView android:id="@+id/nfcSubtext" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" />
            </LinearLayout>
            <LinearLayout android:id="@+id/citizenCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:visibility="gone" android:padding="14dp">
                <TextView android:id="@+id/citizenAvatar" android:layout_width="52dp" android:layout_height="52dp" android:background="#0a6350" android:textColor="#ffffff" android:gravity="center" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="14dp">
                    <TextView android:id="@+id/citizenName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" />
                    <TextView android:id="@+id/citizenId" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/citizenDetails" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#b71c1c" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/docsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
